using System;
using System.Configuration;
using System.Data;
using System.Data.SqlClient;
using System.IO;
using System.Web.UI.WebControls;

namespace drs
{
    public partial class WebForm4 : System.Web.UI.Page
    {
        SqlConnection con = new SqlConnection(ConfigurationManager.ConnectionStrings["dbcon"].ConnectionString);

        protected void Page_Load(object sender, EventArgs e)
        {
            if (Session["sender_id"] == null)
            {
                Response.Redirect("Login.aspx");
            }

            if (!IsPostBack)
            {
                BindGrid();
            }
        }

        void BindGrid()
        {
            SqlDataAdapter da = new SqlDataAdapter(
                "SELECT * FROM tbl_courier WHERE sender_id=@sid", con);

            da.SelectCommand.Parameters.AddWithValue("@sid", Session["sender_id"]);

            DataTable dt = new DataTable();
            da.Fill(dt);

            GridView1.DataSource = dt;
            GridView1.DataBind();
        }

        // 🔹 INSERT
        protected void btnInsert_Click(object sender, EventArgs e)
        {
            if (txtParcelName.Text == "" || txtCharge.Text == "")
            {
                Response.Write("All fields required");
                return;
            }

            int charge;
            if (!int.TryParse(txtCharge.Text, out charge) || charge <= 0)
            {
                Response.Write("Charge must be > 0");
                return;
            }

            string path = "";

            if (fileUpload.HasFile)
            {
                string fileName = fileUpload.FileName;
                path = "Images/" + fileName;
                fileUpload.SaveAs(Server.MapPath(path));
            }

            con.Open();

            SqlCommand cmd = new SqlCommand(
                "INSERT INTO tbl_courier(parcel_category, parcel_name, sender_id, charge, image_path) VALUES(@c,@n,@sid,@ch,@img)", con);

            cmd.Parameters.AddWithValue("@c", ddlCategory.SelectedValue);
            cmd.Parameters.AddWithValue("@n", txtParcelName.Text);
            cmd.Parameters.AddWithValue("@sid", Session["sender_id"]);
            cmd.Parameters.AddWithValue("@ch", charge);
            cmd.Parameters.AddWithValue("@img", path);

            cmd.ExecuteNonQuery();
            con.Close();

            BindGrid();
            Response.Write("Inserted Successfully");
        }

        // 🔹 SELECT → FILL FORM
        protected void GridView1_SelectedIndexChanged(object sender, EventArgs e)
        {
            GridViewRow row = GridView1.SelectedRow;

            hiddenParcelId.Value = row.Cells[1].Text;
            ddlCategory.SelectedValue = row.Cells[2].Text;
            txtParcelName.Text = row.Cells[3].Text;
            txtCharge.Text = row.Cells[4].Text;
        }

        // 🔹 UPDATE (FORM BASED)
        protected void btnUpdate_Click(object sender, EventArgs e)
        {
            if (hiddenParcelId.Value == "")
            {
                Response.Write("Select record first");
                return;
            }

            int charge;
            if (!int.TryParse(txtCharge.Text, out charge) || charge <= 0)
            {
                Response.Write("Charge must be > 0");
                return;
            }

            string path = "";

            if (fileUpload.HasFile)
            {
                string fileName = fileUpload.FileName;
                path = "Images/" + fileName;
                fileUpload.SaveAs(Server.MapPath(path));
            }

            con.Open();

            SqlCommand cmd;

            if (path != "")
            {
                cmd = new SqlCommand(
                    "UPDATE tbl_courier SET parcel_category=@c, parcel_name=@n, charge=@ch, image_path=@img WHERE parcel_id=@id", con);
                cmd.Parameters.AddWithValue("@img", path);
            }
            else
            {
                cmd = new SqlCommand(
                    "UPDATE tbl_courier SET parcel_category=@c, parcel_name=@n, charge=@ch WHERE parcel_id=@id", con);
            }

            cmd.Parameters.AddWithValue("@c", ddlCategory.SelectedValue);
            cmd.Parameters.AddWithValue("@n", txtParcelName.Text);
            cmd.Parameters.AddWithValue("@ch", charge);
            cmd.Parameters.AddWithValue("@id", hiddenParcelId.Value);

            cmd.ExecuteNonQuery();
            con.Close();

            hiddenParcelId.Value = "";
            BindGrid();

            Response.Write("Updated Successfully");
        }

        // 🔹 DELETE
        protected void GridView1_RowDeleting(object sender, System.Web.UI.WebControls.GridViewDeleteEventArgs e)
        {
            int id = Convert.ToInt32(GridView1.DataKeys[e.RowIndex].Value);

            con.Open();
            SqlCommand cmd = new SqlCommand("DELETE FROM tbl_courier WHERE parcel_id=@id", con);
            cmd.Parameters.AddWithValue("@id", id);
            cmd.ExecuteNonQuery();
            con.Close();

            BindGrid();
        }
    }
}
